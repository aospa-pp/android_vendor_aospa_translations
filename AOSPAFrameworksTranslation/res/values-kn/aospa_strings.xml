    <string name="pocket_mode_title">ಪಾಕೆಟ್ ಮೋಡ್ ಸಕ್ರಿಯವಾಗಿದೆ</string>
    <string name="pocket_mode_illustration_description">ಜೇಬಿನಲ್ಲಿ ಫೋನ್‌ನ ವಿವರಣೆ</string>
    <string name="pocket_mode_instructions_header">ನಿಮ್ಮ ಫೋನ್ ಬಳಸಲು:</string>
    <string name="pocket_mode_instruction_step1">1. ಮೇಲೆ ತೋರಿಸಿರುವ ಹಸಿರು ಪ್ರದೇಶ (ಸಾಮೀಪ್ಯ ಸಂವೇದಕ) ತಡೆಯಿಲ್ಲ ಮತ್ತು ಕೊಳಕು ಅಥವಾ ಧೂಳಿನಿಂದ ಮುಕ್ತವಾಗಿದೆ ಎಂದು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ.</string>
    <string name="pocket_mode_instruction_step2">2. ಪಾಕೆಟ್ ಮೋಡ್‌ನಿಂದ ನಿರ್ಗಮಿಸಲು ಪವರ್ ಬಟನ್ ಒತ್ತಿ ಮತ್ತು ಹಿಡಿದುಕೊಳ್ಳಿ.</string>

</resources>