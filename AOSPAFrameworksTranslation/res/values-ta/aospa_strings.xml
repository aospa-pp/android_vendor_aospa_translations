<resources>
    <string name="reboot_to_recovery_title">மீட்பு</string>
    <string name="reboot_to_recovery_message">மீட்புக்கு மறுதொடக்கம்</string>
    <string name="reboot_to_bootloader_title">துவக்க ஏற்றி</string>
    <string name="reboot_to_bootloader_message">துவக்க ஏற்றிக்கு மறுதொடக்கம் செய்தல்</string>
    <string name="reboot_title">மறுதொடக்கம் செய்யுங்கள்</string>
    <string name="reboot_message">மறுதொடக்கம் முறை</string>

    
    <string name="pocket_mode_title">பாக்கெட் பயன்முறை செயலில் உள்ளது</string>
    <string name="pocket_mode_illustration_description">பாக்கெட்டில் தொலைபேசியின் விளக்கம்</string>
    <string name="pocket_mode_instructions_header">உங்கள் தொலைபேசியைப் பயன்படுத்த:</string>
    <string name="pocket_mode_instruction_step1">1. மேலே காட்டப்பட்டுள்ள பசுமை பகுதி (அருகாமையில் சென்சார்) தடையின்றி, அழுக்கு அல்லது தூசியிலிருந்து விடுபடுவதை உறுதிசெய்க.</string>
    <string name="pocket_mode_instruction_step2">2. பாக்கெட் பயன்முறையிலிருந்து வெளியேற பவர் பொத்தானை அழுத்திப் பிடிக்கவும்.</string>

</resources>